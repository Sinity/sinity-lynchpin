use flake

# Ensure local Python imports can resolve the repo root (lynchpin package, etc.).
export PYTHONPATH="${PWD}:${PYTHONPATH:-}"
export LYNCHPIN_DEFAULT_TZ="Europe/Warsaw"
export HPI_HOME_LAT="52.2297"
export HPI_HOME_LON="21.0122"
export LYNCHPIN_GIT_EMAILS="ezo.dev@gmail.com"
export LYNCHPIN_GIT_NAMES="Sinity"

# Cache the banner for up to one hour to avoid recomputing it on every shell entry.
if [ -z "${SINITY_ANALYSIS_BANNER_SHOWN:-}" ]; then
  export SINITY_ANALYSIS_BANNER_SHOWN=1

  cache_file="${HOME}/.cache/sinity-lynchpin-banner"
  cache_valid=0

  # Check if cache exists and is fresh (<1 hour old)
  if [ -f "$cache_file" ]; then
    cache_age=$(($(date +%s) - $(date -r "$cache_file" +%s)))
    if [ "$cache_age" -lt 3600 ]; then
      cache_valid=1
    fi
  fi

  # If cache is valid, just show it
  if [ "$cache_valid" -eq 1 ]; then
    cat "$cache_file"
  else
    # Generate and cache the banner

  repo_branch=""
  if command -v git >/dev/null 2>&1 && git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    repo_branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null)"
  fi

  life_range_file="artefacts/lifelog/life-timeline/life_timeline_latest_range.txt"
  if [ -f "$life_range_file" ]; then
    life_range="$(tr -d '\r\n' < "$life_range_file")"
  else
    life_range="run just life-refresh"
  fi

  life_auto_file="artefacts/lifelog/life-timeline/narratives/life_auto_summary.md"
  if [ -f "$life_auto_file" ]; then
    life_auto_stamp="$(date -u -r "$life_auto_file" '+%Y-%m-%d %H:%M UTC')"
  else
    life_auto_stamp="missing (run just life-auto-narrative)"
  fi

  session_ledger="artefacts/knowledge/ledgers/session_index.csv"
  artefact_ledger="artefacts/knowledge/ledgers/artefact_index.csv"
  if [ -f "$session_ledger" ]; then
    session_stamp="$(date -u -r "$session_ledger" '+%Y-%m-%d')"
  else
    session_stamp="missing"
  fi
  if [ -f "$artefact_ledger" ]; then
    artefact_stamp="$(date -u -r "$artefact_ledger" '+%Y-%m-%d')"
  else
    artefact_stamp="missing"
  fi

  header_title="sinity-analysis"
  if [ -n "$repo_branch" ]; then
    header_title="$header_title · branch $repo_branch"
  fi

  tput_available=0
  if command -v tput >/dev/null 2>&1 && [ -n "${TERM:-}" ]; then
    tput_available=1
    tput_colors="$(tput colors 2>/dev/null || printf '0')"
  else
    tput_colors=0
  fi

  if [ "$tput_available" -eq 1 ] && [ "$tput_colors" -ge 8 ]; then
    C_RESET="$(tput sgr0)"
    C_TITLE="$(tput bold)$(tput setaf 6)"
    C_LABEL="$(tput bold)$(tput setaf 4)"
    C_BORDER="$(tput setaf 8)"
  else
    C_RESET=""
    C_TITLE=""
    C_LABEL=""
    C_BORDER=""
  fi

  term_cols=""
  if [ -n "${COLUMNS:-}" ]; then
    term_cols="${COLUMNS}"
  elif [ "$tput_available" -eq 1 ]; then
    term_cols="$(tput cols 2>/dev/null || true)"
  elif [ -t 1 ] && command -v stty >/dev/null 2>&1; then
    term_cols="$(stty size 2>/dev/null | awk '{print $2}')"
  fi
  case "$term_cols" in
    (''|*[!0-9]*) term_cols="";;
  esac

  inner_width=126
  if [ -n "$term_cols" ]; then
    usable_width=$((term_cols - 4))
    if [ "$usable_width" -gt 0 ] && [ "$usable_width" -lt "$inner_width" ]; then
      inner_width=$usable_width
    fi
  fi

  clip_text() {
    local text="$1"
    local width="$2"
    if [ "$width" -le 0 ]; then
      printf ''
      return
    fi
    local len=${#text}
    if [ "$len" -le "$width" ]; then
      printf '%s' "$text"
    else
      if [ "$width" -le 3 ]; then
        printf '%.*s' "$width" "$text"
      else
        local cut=$((width - 3))
        printf '%s...' "${text:0:cut}"
      fi
    fi
  }

  if [ "$inner_width" -lt 1 ]; then
    inner_width=1
  fi
  border_top="$(printf '╭'; printf '─%.0s' $(seq 1 $inner_width); printf '╮')"
  border_bottom="$(printf '╰'; printf '─%.0s' $(seq 1 $inner_width); printf '╯')"

  banner_line_full() {
    local content
    content="$(clip_text "$1" "$inner_width")"
    printf '│ %s%-*s%s │\n' "$C_TITLE" "$inner_width" "$content" "$C_RESET"
  }

  banner_line_pair() {
    local label="$1"
    local value="$2"
    local label_width=24
    local max_label_width=$((inner_width - 4))
    if [ "$max_label_width" -le 0 ]; then
      banner_line_full "$label: $value"
      return
    fi
    if [ "$label_width" -gt "$max_label_width" ]; then
      label_width=$max_label_width
    fi
    local value_width=$((inner_width - label_width - 3))
    if [ "$value_width" -le 0 ]; then
      banner_line_full "$label: $value"
      return
    fi
    local trimmed_label
    local trimmed_value
    trimmed_label="$(clip_text "$label" "$label_width")"
    trimmed_value="$(clip_text "$value" "$value_width")"
    printf '│ %s%-*s%s : %-*s │\n' "$C_LABEL" "$label_width" "$trimmed_label" "$C_RESET" "$value_width" "$trimmed_value"
  }

  printf '%s%s%s\n' "$C_BORDER" "$border_top" "$C_RESET"
  banner_line_full "$header_title"
  banner_line_pair "Pipelines" "baseline · focus-portal · weekly-focus-report · life-refresh"
  banner_line_pair "Docs map" "docs/reference/repo-organization.md"
  banner_line_pair "Life timeline" "$life_range"
  banner_line_pair "Auto narrative" "$life_auto_stamp"
  banner_line_pair "Ledgers" "sessions $session_stamp · artefacts $artefact_stamp (just refresh-ledgers)"
  banner_line_pair "Artefacts" "artefacts/<theme>/<pipeline>/  (cleanup: just clean-generated)"
  printf '%s%s%s\n' "$C_BORDER" "$border_bottom" "$C_RESET"

    # Cache the banner output
    mkdir -p "${HOME}/.cache"
    {
      printf '%s%s%s\n' "$C_BORDER" "$border_top" "$C_RESET"
      banner_line_full "$header_title"
      banner_line_pair "Pipelines" "baseline · focus-portal · weekly-focus-report · life-refresh"
      banner_line_pair "Docs map" "docs/reference/repo-organization.md"
      banner_line_pair "Life timeline" "$life_range"
      banner_line_pair "Auto narrative" "$life_auto_stamp"
      banner_line_pair "Ledgers" "sessions $session_stamp · artefacts $artefact_stamp (just refresh-ledgers)"
      banner_line_pair "Artefacts" "artefacts/<theme>/<pipeline>/  (cleanup: just clean-generated)"
      printf '%s%s%s\n' "$C_BORDER" "$border_bottom" "$C_RESET"
    } > "$cache_file"
  fi
fi
