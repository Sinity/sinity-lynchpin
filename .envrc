watch_file flake.nix
watch_file flake.lock

export NIX_CONFIG="max-jobs = 2
cores = 4
fallback = true"

use flake .

export LYNCHPIN_LOCAL_ROOT="${PWD}/.lynchpin"
export LYNCHPIN_GENERATED_ROOT="${LYNCHPIN_LOCAL_ROOT}/generated"
export LYNCHPIN_KNOWLEDGEBASE_ROOT="${LYNCHPIN_GENERATED_ROOT}"
export LYNCHPIN_REPO_ARTEFACTS_ROOT="${LYNCHPIN_GENERATED_ROOT}"
export LYNCHPIN_REGISTRY_ROOT="${LYNCHPIN_GENERATED_ROOT}/registry"
export LYNCHPIN_CACHE_DIR="${LYNCHPIN_LOCAL_ROOT}/cache/lynchpin"
export PYTHONPYCACHEPREFIX="${LYNCHPIN_LOCAL_ROOT}/cache/python"
export RUFF_CACHE_DIR="${LYNCHPIN_LOCAL_ROOT}/cache/ruff"
export MYPY_CACHE_DIR="${LYNCHPIN_LOCAL_ROOT}/cache/mypy"
export UV_CACHE_DIR="${LYNCHPIN_LOCAL_ROOT}/cache/uv"
export NPM_CONFIG_CACHE="${LYNCHPIN_LOCAL_ROOT}/cache/npm"
export PLAYWRIGHT_MCP_OUTPUT_DIR="${LYNCHPIN_LOCAL_ROOT}/cache/playwright-mcp"

export LYNCHPIN_DEFAULT_TZ="Europe/Warsaw"
PATH_add tool
