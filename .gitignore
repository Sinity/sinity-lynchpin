# Nix & Direnv
.direnv/
result

# Repo-local generated working state. New ad hoc caches, temporary outputs,
# rescued material, and handoff bundles belong here.
.lynchpin/

# Python user installs / caches
.pyuser/
.jupyter/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.venv/
.benchmarks/

# R libraries
.rlib/

# Local raw datasets (heavy, non-versioned)
data/raw/

# Local agent scratch and personal-analysis reports (financial data, private
# chat excerpts — reviewed content-by-content, genuinely private). Kept on
# disk and covered by the regular backup, not git. .agent/tools/ is NOT
# listed here (git can't un-ignore a path under an ignored parent dir):
# reviewed content-by-content and found to be generic, reusable, non-personal
# tooling, so it stays trackable.
.agent/reports/
.agent/scratch/
.agent/handoff/
.agent/ops/
.claude/settings.local.json
.claude/*.lock

